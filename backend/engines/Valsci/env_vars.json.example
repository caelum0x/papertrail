{
    "FLASK_SECRET_KEY": "your_secret_key_here",
    "USER_EMAIL": "your_email@example.com",
    "SEMANTIC_SCHOLAR_API_KEY": "your_semantic_scholar_api_key",
    "SEMANTIC_SCHOLAR_MANIFEST": "mendelian_v1.json",

    "LLM_PROVIDER": "openai",
    "LLM_API_KEY": "your_api_key",
    "LLM_EVALUATION_MODEL": "gpt-4o",
    "LLM_BASE_URL": "https://api.openai.com/v1",
    "LOCAL_MODEL_CONTEXT_OVERRIDE": 0,
    
    "REQUIRE_PASSWORD": "true",
    "ACCESS_PASSWORD": "your_access_password",
    
    "AZURE_OPENAI_ENDPOINT": "",
    "AZURE_OPENAI_API_VERSION": "2024-06-01",
    "AZURE_AI_INFERENCE_ENDPOINT": "",
    
    "ENABLE_EMAIL_NOTIFICATIONS": "false",
    "EMAIL_SENDER": "",
    "EMAIL_APP_PASSWORD": "",
    "SMTP_SERVER": "smtp.gmail.com",
    "SMTP_PORT": "587",
    "BASE_URL": "http://localhost:3000",

    "TRACE_ENABLED": true,
    "STATE_DIR": "state",
    "PROVIDER_CATALOG_PATH": "state/provider_catalog.json",
    "TRACE_DIR": "saved_jobs",
    "TRACE_EMBED_MODE": "capped",
    "TRACE_EMBED_MAX_BYTES": 2000000,
    "TRACE_STACKTRACE_MAX_BYTES": 4000,
    "TRACE_ALWAYS_WRITE_FILES": true,
    "TRACE_COMPRESS_ON_COMPLETE": false,

    "LLM_CONTEXT_SAFETY_MARGIN_TOKENS": 256,
    "LLM_MAX_CONCURRENCY": 5,
    "LLM_REQUESTS_PER_MINUTE": 240,
    "LLM_TOKENS_PER_MINUTE": 2000000,
    "LLM_MAX_RETRIES": 3,
    "LLM_BACKOFF_BASE_SECONDS": 1.0,
    "LLM_BACKOFF_MAX_SECONDS": 30.0,
    "LLM_BACKOFF_JITTER": 0.5,
    "LLM_TIMEOUT_SECONDS": 180,
    "LLM_TIMEOUT_SECONDS_LOCAL": 600,

    "LLM_ROUTING": {
        "enabled": true,
        "locked_models": false,
        "tasks": {
            "query_generation": {
                "preferred_models": ["gpt-4o-mini"],
                "fallback_models": ["gpt-4o"],
                "max_output_tokens": 800,
                "timeout_seconds": 300
            },
            "paper_analysis": {
                "preferred_models": ["gpt-4o"],
                "fallback_models": ["gpt-5-mini"],
                "max_output_tokens": 1200,
                "min_context_tokens": 16000
            },
            "venue_scoring": {
                "preferred_models": ["gpt-4o-mini"],
                "fallback_models": ["gpt-4o"],
                "max_output_tokens": 120
            },
            "final_report": {
                "preferred_models": ["gpt-5"],
                "fallback_models": ["gpt-4o"],
                "max_output_tokens": 1800
            }
        }
    },

    "MODEL_REGISTRY_OVERRIDES": {},
    "OLLAMA_SHOW_URL": ""
}
